#!/usr/bin/env bash
set -euo pipefail

repo_root=$(git rev-parse --show-toplevel 2>/dev/null || true)
if [[ -z "$repo_root" ]]; then
  repo_root=$(cd "$(dirname "$0")/.." && pwd)
fi
cd "$repo_root"

recipients_file="secrets/recipients.nix"
rules_file="secrets/secrets.nix"
home_secrets_file="modules/home-manager/secrets.nix"

usage() {
  cat <<'USAGE'
Usage: scripts/secrets [command]

Interactive agenix helper for this repo.

Commands:
  menu          Open the interactive menu (default)
  audit         Check secret declarations, files, recipients, and identities
  create        Create a new encrypted secret and recipient rule
  edit          Edit an existing encrypted secret
  host-key      Generate/import a host key, optionally grant existing secrets
  rekey         Re-encrypt all secrets from secrets/secrets.nix
  list          List declared secrets and host recipients

Aliases:
  onboard-host  Same as host-key

Examples:
  scripts/secrets
  scripts/secrets audit
  scripts/secrets create
USAGE
}

die() {
  echo "Error: $*" >&2
  exit 1
}

need() {
  command -v "$1" >/dev/null 2>&1 || die "Missing required command: $1"
}

ensure_deps() {
  need nix
  need jq
  need agenix
  need ssh-keygen
}

confirm() {
  local prompt="$1"
  local answer
  read -r -p "$prompt [Y/n] " answer
  [[ -z "$answer" || "$answer" =~ ^[Yy]$ ]]
}

prompt_required() {
  local prompt="$1"
  local value
  while true; do
    read -r -p "$prompt " value
    if [[ -n "$value" ]]; then
      printf '%s\n' "$value"
      return 0
    fi
  done
}

validate_name() {
  local name="$1"
  [[ "$name" =~ ^[A-Za-z0-9_-]+$ ]] || die "Use only letters, numbers, underscores, and dashes: $name"
}

validate_host() {
  local host="$1"
  [[ "$host" =~ ^[A-Za-z0-9_-]+$ ]] || die "Use only letters, numbers, underscores, and dashes: $host"
}

validate_public_key() {
  local pubkey="$1"
  local tmp
  tmp=$(mktemp)
  printf '%s\n' "$pubkey" >"$tmp"
  if ! ssh-keygen -l -f "$tmp" >/dev/null 2>&1; then
    rm -f "$tmp"
    die "That does not look like a valid SSH public key."
  fi
  rm -f "$tmp"
}

escape_nix_string() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  printf '%s' "$value"
}

nix_eval() {
  nix eval --impure --json --expr "$1"
}

recipients_json() {
  nix_eval "import ./${recipients_file}"
}

rules_json() {
  nix_eval "import ./${rules_file}"
}

recipient_names() {
  recipients_json | jq -r 'keys[]' | sort
}

secret_files_declared() {
  rules_json | jq -r 'keys[]' | sort
}

secret_names_declared() {
  secret_files_declared | sed 's/\.age$//' | sort
}

require_clean_rules_mapping() {
  local rec_json="$1"
  local sec_json="$2"
  local unknown
  unknown=$(jq -r --slurpfile recipients "$rec_json" '
    ($recipients[0] | to_entries | map(.value)) as $known
    | [
        to_entries[]
        | .key as $secret
        | ((.value.publicKeys // []) - $known)[]?
        | "\($secret): \(.)"
      ]
    | .[]
  ' "$sec_json")

  if [[ -n "$unknown" ]]; then
    echo "Some secrets use public keys that are not in $recipients_file:" >&2
    echo "$unknown" | sed 's/^/  /' >&2
    die "Refusing to rewrite $rules_file until recipients are named."
  fi
}

current_rules_tsv() {
  local rec_json sec_json
  rec_json=$(mktemp)
  sec_json=$(mktemp)

  recipients_json >"$rec_json"
  rules_json >"$sec_json"
  require_clean_rules_mapping "$rec_json" "$sec_json"

  jq -r --slurpfile recipients "$rec_json" '
    to_entries[]
    | .key as $secret
    | (.value.publicKeys // [])[] as $key
    | ($recipients[0] | to_entries[] | select(.value == $key) | .key) as $host
    | [$secret, $host]
    | @tsv
  ' "$sec_json" | sort -u
  rm -f "$rec_json" "$sec_json"
}

write_rules_from_tsv() {
  local tsv="$1"
  local tmp
  tmp=$(mktemp)

  {
    echo "let"
    echo "  recipients = import ./recipients.nix;"
    echo "in"
    echo "{"

    if [[ -s "$tsv" ]]; then
      while IFS= read -r secret; do
        [[ -n "$secret" ]] || continue
        mapfile -t hosts < <(awk -F '\t' -v secret="$secret" '$1 == secret { print $2 }' "$tsv" | sort -u)
        if [[ ${#hosts[@]} -eq 1 ]]; then
          printf '  "%s".publicKeys = [ recipients."%s" ];\n' "$secret" "${hosts[0]}"
        else
          printf '  "%s".publicKeys = [\n' "$secret"
          for host in "${hosts[@]}"; do
            printf '    recipients."%s"\n' "$host"
          done
          echo "  ];"
        fi
      done < <(cut -f1 "$tsv" | sort -u)
    fi

    echo "}"
  } >"$tmp"

  mv "$tmp" "$rules_file"
  nixfmt "$rules_file"
}

add_rule_hosts() {
  local secret_file="$1"
  shift
  local tsv
  tsv=$(mktemp)

  current_rules_tsv >"$tsv"
  for host in "$@"; do
    printf '%s\t%s\n' "$secret_file" "$host" >>"$tsv"
  done
  sort -u "$tsv" -o "$tsv"
  write_rules_from_tsv "$tsv"
  rm -f "$tsv"
}

host_exists() {
  local host="$1"
  recipients_json | jq -e --arg host "$host" 'has($host)' >/dev/null
}

secret_declared() {
  local secret_file="$1"
  rules_json | jq -e --arg secret "$secret_file" 'has($secret)' >/dev/null
}

age_file_exists() {
  local secret_file="$1"
  [[ -f "secrets/$secret_file" ]]
}

select_one() {
  local prompt="$1"
  shift
  local items=("$@")
  local answer

  [[ ${#items[@]} -gt 0 ]] || die "Nothing to select."
  echo "$prompt"
  for i in "${!items[@]}"; do
    printf '  %d. %s\n' "$((i + 1))" "${items[$i]}"
  done

  while true; do
    read -r -p "> " answer
    if [[ "$answer" =~ ^[0-9]+$ ]] && (( answer >= 1 && answer <= ${#items[@]} )); then
      SELECTED_ONE="${items[$((answer - 1))]}"
      return 0
    fi
    echo "Enter a number from 1-${#items[@]}."
  done
}

select_many() {
  local prompt="$1"
  shift
  local items=("$@")
  local answer token idx

  SELECTED_MANY=()
  [[ ${#items[@]} -gt 0 ]] || die "Nothing to select."

  echo "$prompt"
  for i in "${!items[@]}"; do
    printf '  %d. %s\n' "$((i + 1))" "${items[$i]}"
  done
  echo "Enter numbers separated by spaces, or 'all'."

  while true; do
    read -r -p "> " answer
    if [[ "$answer" == "all" ]]; then
      SELECTED_MANY=("${items[@]}")
      return 0
    fi

    SELECTED_MANY=()
    local ok=true
    for token in $answer; do
      if [[ "$token" =~ ^[0-9]+$ ]] && (( token >= 1 && token <= ${#items[@]} )); then
        idx=$((token - 1))
        SELECTED_MANY+=("${items[$idx]}")
      else
        ok=false
      fi
    done

    if [[ "$ok" == true && ${#SELECTED_MANY[@]} -gt 0 ]]; then
      mapfile -t SELECTED_MANY < <(printf '%s\n' "${SELECTED_MANY[@]}" | sort -u)
      return 0
    fi
    echo "Enter valid numbers from 1-${#items[@]}, or 'all'."
  done
}

choose_identity() {
  local identity_glob="$HOME/.ssh/id_ed25519_agenix_*"
  local identities=()
  local identity

  while IFS= read -r identity; do
    identities+=("$identity")
  done < <(find "$HOME/.ssh" -maxdepth 1 -type f -name 'id_ed25519_agenix_*' ! -name '*.pub' 2>/dev/null | sort)

  if [[ ${#identities[@]} -eq 1 ]]; then
    SELECTED_IDENTITY="${identities[0]}"
    return 0
  fi

  if [[ ${#identities[@]} -gt 1 ]]; then
    select_one "Which agenix identity should be used?" "${identities[@]}"
    SELECTED_IDENTITY="$SELECTED_ONE"
    return 0
  fi

  echo "No agenix identity found matching $identity_glob"
  read -r -p "Identity path to use, or blank to let agenix try defaults: " SELECTED_IDENTITY
}

run_agenix_edit() {
  local secret_file="$1"
  shift || true
  local args=(-e "$secret_file")
  if [[ -n "${1:-}" ]]; then
    args+=(-i "$1")
  fi

  (
    cd secrets
    RULES=./secrets.nix agenix "${args[@]}"
  )
}

run_agenix_rekey() {
  local identity="${1:-}"
  local args=(-r)
  if [[ -n "$identity" ]]; then
    args+=(-i "$identity")
  fi

  (
    cd secrets
    RULES=./secrets.nix agenix "${args[@]}"
  )
}

cmd_list() {
  echo "Recipients:"
  recipient_names | sed 's/^/  - /'
  echo ""
  echo "Secrets:"

  local rec_json sec_json
  rec_json=$(mktemp)
  sec_json=$(mktemp)
  recipients_json >"$rec_json"
  rules_json >"$sec_json"

  jq -r --slurpfile recipients "$rec_json" '
    to_entries[]
    | .key as $secret
    | (.value.publicKeys // []) as $keys
    | ($recipients[0] | to_entries | map(select(.value as $key | $keys | index($key)).key) | sort) as $hosts
    | "  - \($secret): \($hosts | join(", "))"
  ' "$sec_json"
  rm -f "$rec_json" "$sec_json"
}

cmd_audit() {
  local failed=0
  local rec_json sec_json declared_files age_files hm_files unknown
  rec_json=$(mktemp)
  sec_json=$(mktemp)

  recipients_json >"$rec_json"
  rules_json >"$sec_json"

  echo "Agenix audit"
  echo ""

  mapfile -t declared_files < <(jq -r 'keys[]' "$sec_json" | sort)
  mapfile -t age_files < <(find secrets -maxdepth 1 -type f -name '*.age' -exec basename {} \; | sort)
  mapfile -t hm_files < <(grep -Eo '\.\./\.\./secrets/[A-Za-z0-9_-]+\.age' "$home_secrets_file" 2>/dev/null | sed 's#../../secrets/##' | sort -u || true)

  unknown=$(jq -r --slurpfile recipients "$rec_json" '
    ($recipients[0] | to_entries | map(.value)) as $known
    | [to_entries[] | .key as $secret | ((.value.publicKeys // []) - $known)[]? | "\($secret)"]
    | unique[]
  ' "$sec_json")

  if [[ -z "$unknown" ]]; then
    echo "✓ Every secret recipient is named in $recipients_file"
  else
    echo "✗ Some secrets use unnamed public keys:"
    echo "$unknown" | sed 's/^/  - /'
    failed=1
  fi

  local item found
  for item in "${declared_files[@]}"; do
    if [[ ! -f "secrets/$item" ]]; then
      echo "✗ Declared secret is missing file: secrets/$item"
      failed=1
    fi
  done
  if [[ $failed -eq 0 ]]; then
    echo "✓ Every declared secret file exists"
  fi

  for item in "${age_files[@]}"; do
    found=false
    for declared in "${declared_files[@]}"; do
      [[ "$item" == "$declared" ]] && found=true
    done
    if [[ "$found" == false ]]; then
      echo "? Age file is not declared in $rules_file: secrets/$item"
    fi
  done

  for item in "${hm_files[@]}"; do
    found=false
    for declared in "${declared_files[@]}"; do
      [[ "$item" == "$declared" ]] && found=true
    done
    if [[ "$found" == false ]]; then
      echo "✗ Home Manager references undeclared secret: $item"
      failed=1
    fi
  done

  local host identity
  while IFS= read -r host; do
    identity="$HOME/.ssh/id_ed25519_agenix_${host}"
    if [[ -f "$identity" ]]; then
      echo "✓ Identity exists for $host: $identity"
    else
      echo "? Identity not found for $host: $identity"
    fi
  done < <(jq -r 'keys[]' "$rec_json" | sort)

  echo ""
  rm -f "$rec_json" "$sec_json"

  if [[ $failed -eq 0 ]]; then
    echo "Audit completed."
  else
    die "Audit failed."
  fi
}

cmd_create() {
  local name secret_file hosts add_hm
  name=$(prompt_required "Secret name, without .age:")
  name="${name%.age}"
  validate_name "$name"
  secret_file="$name.age"

  secret_declared "$secret_file" && die "Already declared: $secret_file"
  age_file_exists "$secret_file" && die "File already exists: secrets/$secret_file"

  mapfile -t hosts < <(recipient_names)
  select_many "Which hosts should decrypt $secret_file?" "${hosts[@]}"

  echo ""
  echo "Planned changes:"
  echo "  ~ $rules_file"
  echo "  + secrets/$secret_file"
  if confirm "Add Home Manager age.secrets.$name entry?"; then
    add_hm=true
    echo "  ~ $home_secrets_file"
  else
    add_hm=false
  fi
  confirm "Continue?" || exit 0

  add_rule_hosts "$secret_file" "${SELECTED_MANY[@]}"

  if [[ "$add_hm" == true ]]; then
    if grep -q "secrets\.$name\.file" "$home_secrets_file"; then
      echo "Home Manager already has age.secrets.$name; leaving it unchanged."
    else
      perl -0pi -e "s|(\n  \};\n\}\s*)$|\n    secrets.$name.file = ../../secrets/$secret_file;\$1|" "$home_secrets_file"
      nixfmt "$home_secrets_file"
    fi
  fi

  echo "Opening editor via agenix..."
  run_agenix_edit "$secret_file"
}

cmd_edit() {
  local secrets secret_file identity
  mapfile -t secrets < <(secret_files_declared)
  select_one "Which secret should be edited?" "${secrets[@]}"
  secret_file="$SELECTED_ONE"

  choose_identity
  identity="$SELECTED_IDENTITY"
  echo "Editing secrets/$secret_file"
  if [[ -n "$identity" ]]; then
    echo "Using identity: $identity"
  fi
  run_agenix_edit "$secret_file" "$identity"
}

cmd_onboard_host() {
  local host default_key default_pub pubkey existing_secrets grant_secrets tsv identity
  host=$(prompt_required "Host name:")
  validate_host "$host"
  host_exists "$host" && die "Recipient already exists: $host"

  default_key="$HOME/.ssh/id_ed25519_agenix_${host}"
  default_pub="${default_key}.pub"
  echo ""
  echo "Expected keypair:"
  echo "  private: $default_key"
  echo "  public:  $default_pub"

  if [[ -f "$default_pub" ]]; then
    select_one "How should the host public key be sourced?" \
      "Use existing public key" \
      "Paste public key" \
      "Cancel"
    case "$SELECTED_ONE" in
      "Use existing public key") pubkey=$(<"$default_pub") ;;
      "Paste public key")
        echo "Paste the host public key, e.g. ssh-ed25519 AAAA... agenix@$host"
        pubkey=$(prompt_required "Public key:")
        ;;
      "Cancel") exit 0 ;;
    esac
  elif [[ -f "$default_key" ]]; then
    select_one "Private key exists but public key is missing. What should happen?" \
      "Derive public key" \
      "Paste public key" \
      "Cancel"
    case "$SELECTED_ONE" in
      "Derive public key")
        ssh-keygen -y -f "$default_key" >"$default_pub"
        pubkey=$(<"$default_pub")
        echo "Derived public key: $default_pub"
        ;;
      "Paste public key")
        echo "Paste the host public key, e.g. ssh-ed25519 AAAA... agenix@$host"
        pubkey=$(prompt_required "Public key:")
        ;;
      "Cancel") exit 0 ;;
    esac
  else
    select_one "How should the agenix keypair be onboarded?" \
      "Generate new keypair" \
      "Paste public key" \
      "Cancel"
    case "$SELECTED_ONE" in
      "Generate new keypair")
        echo ""
        echo "Planned local files:"
        echo "  + $default_key"
        echo "  + $default_pub"
        confirm "Generate this keypair with no passphrase?" || exit 0
        mkdir -p "$HOME/.ssh"
        chmod 700 "$HOME/.ssh"
        ssh-keygen -q -t ed25519 -N "" -C "agenix@$host" -f "$default_key"
        pubkey=$(<"$default_pub")
        echo "Generated keypair. Keep the private key on this host only."
        ;;
      "Paste public key")
        echo "Paste the host public key, e.g. ssh-ed25519 AAAA... agenix@$host"
        pubkey=$(prompt_required "Public key:")
        ;;
      "Cancel") exit 0 ;;
    esac
  fi

  validate_public_key "$pubkey"

  echo ""
  echo "Planned changes:"
  echo "  ~ $recipients_file"
  confirm "Continue?" || exit 0

  local pubkey_nix tmp_recipients
  pubkey_nix=$(escape_nix_string "$pubkey")
  tmp_recipients=$(mktemp)
  awk -v host="$host" -v pubkey="$pubkey_nix" '
    /^[[:space:]]*}[[:space:]]*$/ && !inserted {
      printf "  \"%s\" = \"%s\";\n", host, pubkey
      inserted = 1
    }
    { print }
  ' "$recipients_file" >"$tmp_recipients"
  mv "$tmp_recipients" "$recipients_file"
  nixfmt "$recipients_file"
  echo "Added recipient: $host"

  mapfile -t existing_secrets < <(secret_files_declared)
  if [[ ${#existing_secrets[@]} -gt 0 ]] && confirm "Grant $host access to existing secrets?"; then
    select_many "Which secrets should $host decrypt?" "${existing_secrets[@]}"
    tsv=$(mktemp)
    current_rules_tsv >"$tsv"
    for secret in "${SELECTED_MANY[@]}"; do
      printf '%s\t%s\n' "$secret" "$host" >>"$tsv"
    done
    sort -u "$tsv" -o "$tsv"
    write_rules_from_tsv "$tsv"
    rm -f "$tsv"
    grant_secrets=true
  else
    grant_secrets=false
  fi

  if [[ "$grant_secrets" == true ]] && confirm "Rekey all secrets now?"; then
    choose_identity
    identity="$SELECTED_IDENTITY"
    run_agenix_rekey "$identity"
  else
    echo "Next: scripts/secrets rekey"
  fi
}

cmd_rekey() {
  local identity
  echo "This will rewrite encrypted .age files according to $rules_file."
  confirm "Continue?" || exit 0
  choose_identity
  identity="$SELECTED_IDENTITY"
  run_agenix_rekey "$identity"
}

cmd_menu() {
  local options=(
    "Create a new secret"
    "Edit an existing secret"
    "Generate/import host key"
    "Rekey secrets"
    "Audit secrets"
    "List current setup"
  )
  select_one "Agenix secrets helper" "${options[@]}"
  case "$SELECTED_ONE" in
    "Create a new secret") cmd_create ;;
    "Edit an existing secret") cmd_edit ;;
    "Generate/import host key") cmd_onboard_host ;;
    "Rekey secrets") cmd_rekey ;;
    "Audit secrets") cmd_audit ;;
    "List current setup") cmd_list ;;
  esac
}

ensure_deps

case "${1:-menu}" in
  menu) cmd_menu ;;
  audit) cmd_audit ;;
  create) cmd_create ;;
  edit) cmd_edit ;;
  host-key|onboard-host) cmd_onboard_host ;;
  rekey) cmd_rekey ;;
  list) cmd_list ;;
  -h|--help|help) usage ;;
  *)
    usage >&2
    exit 2
    ;;
esac
