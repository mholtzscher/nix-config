#!/usr/bin/env python3
"""Temporary local receiver for the opencode session uploader plugin."""

from __future__ import annotations

import argparse
import datetime as dt
import json
import re
import sys
import tempfile
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path
from typing import Any


def safe_name(value: Any, fallback: str) -> str:
    text = str(value or fallback)
    text = re.sub(r"[^a-zA-Z0-9_.-]+", "-", text).strip("-.")
    return text[:120] or fallback


def summarize(payload: dict[str, Any]) -> str:
    session = payload.get("session") or {}
    if isinstance(session, dict) and "data" in session and isinstance(session["data"], dict):
        session = session["data"]

    messages = payload.get("messages")
    if isinstance(messages, dict) and "data" in messages:
        messages = messages["data"]

    session_id = session.get("id") if isinstance(session, dict) else None
    title = session.get("title") if isinstance(session, dict) else None
    trigger = payload.get("trigger")
    message_count = len(messages) if isinstance(messages, list) else "?"

    return f"session={session_id or '?'} trigger={trigger or '?'} messages={message_count} title={title or ''}".rstrip()


class Receiver(BaseHTTPRequestHandler):
    server: "ReceiverServer"

    def log_message(self, fmt: str, *args: Any) -> None:
        if self.server.verbose:
            super().log_message(fmt, *args)

    def do_GET(self) -> None:  # noqa: N802 - stdlib handler API
        if self.path in ("/", "/health", "/healthz"):
            self.send_response(200)
            self.send_header("content-type", "text/plain; charset=utf-8")
            self.end_headers()
            self.wfile.write(b"ok\n")
            return
        self.send_error(404, "not found")

    def do_POST(self) -> None:  # noqa: N802 - stdlib handler API
        if self.server.token:
            expected = f"Bearer {self.server.token}"
            actual = self.headers.get("authorization", "")
            if actual != expected:
                self.send_error(401, "expected Authorization: Bearer <token>")
                return

        length = int(self.headers.get("content-length", "0") or "0")
        body = self.rfile.read(length)

        try:
            payload = json.loads(body.decode("utf-8"))
        except Exception as error:
            self.send_error(400, f"invalid json: {error}")
            return

        now = dt.datetime.now(dt.UTC).strftime("%Y%m%dT%H%M%SZ")
        session = payload.get("session") if isinstance(payload, dict) else {}
        if isinstance(session, dict) and "data" in session and isinstance(session["data"], dict):
            session = session["data"]
        session_id = session.get("id") if isinstance(session, dict) else None
        trigger = payload.get("trigger") if isinstance(payload, dict) else None

        filename = f"{now}-{safe_name(session_id, 'unknown-session')}-{safe_name(trigger, 'event')}.json"
        path = self.server.output_dir / filename
        path.write_text(json.dumps(payload, indent=2, sort_keys=True) + "\n", encoding="utf-8")

        print(f"\n[{now}] received {self.path}")
        if isinstance(payload, dict):
            print(f"  {summarize(payload)}")
        print(f"  saved: {path}")
        sys.stdout.flush()

        self.send_response(202)
        self.send_header("content-type", "application/json")
        self.end_headers()
        self.wfile.write(json.dumps({"ok": True, "path": str(path)}).encode("utf-8"))


class ReceiverServer(ThreadingHTTPServer):
    def __init__(self, server_address: tuple[str, int], handler: type[BaseHTTPRequestHandler], output_dir: Path, token: str | None, verbose: bool):
        super().__init__(server_address, handler)
        self.output_dir = output_dir
        self.token = token
        self.verbose = verbose


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--host", default="127.0.0.1", help="Host to bind, default: 127.0.0.1")
    parser.add_argument("--port", type=int, default=8765, help="Port to bind, default: 8765")
    parser.add_argument(
        "--dir",
        type=Path,
        default=Path(tempfile.gettempdir()) / "opencode-session-uploads",
        help="Directory for received JSON files, default: /tmp/opencode-session-uploads",
    )
    parser.add_argument("--token", help="Optional bearer token to require")
    parser.add_argument("--verbose", action="store_true", help="Show HTTP access logs")
    args = parser.parse_args()

    args.dir.mkdir(parents=True, exist_ok=True)
    server = ReceiverServer((args.host, args.port), Receiver, args.dir, args.token, args.verbose)
    url = f"http://{args.host}:{args.port}/upload"

    print("opencode session receiver listening")
    print(f"  url: {url}")
    print(f"  dir: {args.dir}")
    print("\nRun opencode with:")
    print(f"  OPENCODE_SESSION_UPLOAD_URL={url} opencode")
    if args.token:
        print(f"  OPENCODE_SESSION_UPLOAD_TOKEN={args.token} OPENCODE_SESSION_UPLOAD_URL={url} opencode")
    print("\nPress Ctrl-C to stop.\n")

    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\nstopped")
        return 0


if __name__ == "__main__":
    raise SystemExit(main())
